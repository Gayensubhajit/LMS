# Set default behavior to handle all files as text and force LF line endings.
* text=auto eol=lf

# Explicitly ensure shell scripts and other binary-like text files use LF.
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf

# Preserve binary files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.webp binary
